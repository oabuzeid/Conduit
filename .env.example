# Required
ANTHROPIC_API_KEY=sk-ant-...

# Linear (required if tickets.provider is "linear")
LINEAR_API_KEY=lin_api_...

# Jira (required if tickets.provider is "jira")
JIRA_HOST=yourcompany.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=...

# Figma (required for `specbot audit` and Figma comment posting)
FIGMA_ACCESS_TOKEN=...
